{
  "ann_dataset": {
    "name": "fashion_mnist",
    "sampling_method": "first_n",
    "limit": 10000,
    "seed": 42
  },
  "faiss": {
    "config": {
      "nprobe": 24,
      "num_training_vectors": 60000,
      "nlist": 245
    },
    "backend": "cpu",
    "metric": "L2",
    "top_k": 1,
    "batch_size": 2000,
    "method": "ivf",
    "use_cache": false
  }
}